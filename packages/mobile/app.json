{
  "expo": {
    "name": "Mesher",
    "slug": "mesher",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon-ios-light.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/icon-ios-dark.png",
            "resizeMode": "contain",
            "backgroundColor": "#0a0a0a"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Camera is used to scan pairing QR codes.",
          "recordAudioAndroid": false
        }
      ],
      "./plugins/withMesherStripPushEntitlement",
      "expo-notifications",
      "./plugins/withMesherBle"
    ],
    "ios": {
      "icon": {
        "light": "./assets/icon-ios-light.png",
        "dark": "./assets/icon-ios-dark.png"
      },
      "supportsTablet": true,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Mesher uses Bluetooth to discover nearby devices and relay encrypted messages when you use a dev build with BLE enabled.",
        "NSCameraUsageDescription": "Camera is used to scan pairing QR codes.",
        "UIBackgroundModes": ["bluetooth-central", "bluetooth-peripheral"]
      },
      "bundleIdentifier": "com.sebhdz.mesher"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_ADVERTISE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.sebhdz.mesher"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
